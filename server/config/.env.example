# ─────────────────────────
# Server
# ─────────────────────────
PORT=3000
API_ORIGIN=http://localhost:3000
API_PATH=/api
SECURE=false

# ─────────────────────────
# Puppeteer / Chrome
# ─────────────────────────
# FAKE PATH — replace with real Chrome/Chromium path
PUPPETEER_CHROME_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# ─────────────────────────
# Logging
# ─────────────────────────
LOG_TO_FILE=false
LOG_TO_CONSOLE=true
LOG_HTTP=true

# ─────────────────────────
# Email (SMTP)
# ─────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_AUTH_USERNAME=example@gmail.com
EMAIL_AUTH_PASSWORD=FAKE_EMAIL_PASSWORD

# ─────────────────────────
# MongoDB
# ─────────────────────────

# FAKE CONNECTION STRING
MONGO_CONN_STR=mongodb+srv://fakeUser:fakePassword@fake-cluster.mongodb.net/fake-db

# ─────────────────────────
# JWT Tokens
# ─────────────────────────

ACCESS_JWT_SECRET=FAKE_ACCESS_SECRET
ACCESS_JWT_NAME=access_token
ACCESS_JWT_EXPR=900

REFRESH_JWT_SECRET=FAKE_REFRESH_SECRET
REFRESH_JWT_NAME=refresh_token
REFRESH_JWT_EXPR=604800

VERIFY_JWT_SECRET=FAKE_VERIFY_SECRET
VERIFY_JWT_NAME=verify_token


# ─────────────────────────
# OpenAI
# ─────────────────────────

OPENAI_API_KEY=FAKE_OPENAI_API_KEY
OPENAI_LLM_MODEL=gpt-4.1-mini
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large
OPENAI_EMBEDDINGS_MODEL_DIMENSIONALITY=3072


# ─────────────────────────
# Cohere
# ─────────────────────────

COHERE_API_KEY=FAKE_COHERE_API_KEY


# ─────────────────────────
# Pinecone
# ─────────────────────────

PINECONE_API_KEY=FAKE_PINECONE_API_KEY
PINECONE_RAG_INDEX_NAME=example-rag-index
PINECONE_CSP=aws
PINECONE_CSP_REGION=us-east-1


# ─────────────────────────
# Azure Blob Storage
# ─────────────────────────

# FAKE CONNECTION STRING
AZURE_CONN_STR=DefaultEndpointsProtocol=https;AccountName=fakeaccount;AccountKey=fakekey;EndpointSuffix=core.windows.net
AZURE_CONTAINER_NAME=example-container


# ─────────────────────────
# YouTube API
# ─────────────────────────

YOUTUBE_API_KEY=FAKE_YOUTUBE_API_KEY


# ─────────────────────────
# Reddit API
# ─────────────────────────

REDDIT_CLIENT_ID=FAKE_REDDIT_CLIENT_ID
REDDIT_CLIENT_SECRET=FAKE_REDDIT_CLIENT_SECRET
REDDIT_USER_AGENT=example-app/1.0 by u/exampleuser
REDDIT_USERNAME=fake_reddit_user
REDDIT_PASSWORD=FAKE_REDDIT_PASSWORD


# ─────────────────────────
# Defaults (currently unused)
# ─────────────────────────

DEFAULT_PAGINATION_SKIP=0
DEFAULT_PAGINATION_LIMIT=25
DEFAULT_PAGINATION_MAX_LIMIT=100

DEFAULT_CHUNKING_SIZE=1000
DEFAULT_CHUNKING_OVERLAP=200
DEFAULT_CHUNKING_BATCH_SIZE=10
