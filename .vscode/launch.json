{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {   
            "name": "Debug Server",
            "preLaunchTask": "npm: build - server",
            "type": "node",
            "runtimeExecutable": "npx",
            "runtimeArgs": [
                "tsx",
                "--inspect",
                "--tsconfig",
                "${workspaceFolder}/server/tsconfig.json"
            ],
            "args": ["${workspaceFolder}/server/src/index.ts"],
            "sourceMaps": true,
            "resolveSourceMapLocations": [
                "${workspaceFolder}/server/dist/**/*.js",
                "${workspaceFolder}/server/src/**/*.ts"
            ],
            "skipFiles": [
                "<node_internals>/**",
            ],
            "env": {
                "APP_ENV": "test",
                "VSCODE_DEBUG": "true"
            },
        },
        {   
            "name": "Debug Seeding",
            "preLaunchTask": "npm: build - server",
            "type": "node",
            "runtimeExecutable": "npx",
            "runtimeArgs": [
                "tsx",
                "--inspect"
            ],
            "args": ["${workspaceFolder}/server/seeding/seed.ts"],
            "sourceMaps": true,
            "resolveSourceMapLocations": [
                "${workspaceFolder}/server/dist/**/*.js",
                "${workspaceFolder}/server/seeding/**/*.ts"
            ],
            "skipFiles": [
                "<node_internals>/**",
            ],
            "env": {
                "APP_ENV": "test",
                "VSCODE_DEBUG": "true"
            },
        },
        {   
            "preLaunchTask": "npm: build - server",
            "args": [
                "-u",
                "bdd",
                "--timeout",
                "999999",
                "--colors",
                "${workspaceFolder}/server/dist/test/**/*.js",
                "--require",
                "${workspaceFolder}/server/dist/test/fixtures.js",
                // Specify test.
                // "-g",
                // "'Board Controller'"
            ],
            "internalConsoleOptions": "openOnSessionStart",
            "name": "Mocha Tests",
            "env": {
                "APP_ENV": "test",
                "VSCODE_DEBUG": "true"
            },
            "program": "${workspaceFolder}/server/node_modules/mocha/bin/_mocha",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**",
            ],
            "type": "node"
          }
    ]
}